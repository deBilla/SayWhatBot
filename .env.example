# Copy this file to `.env` and fill in the values, then `docker compose up --build`.

# Random secret used to sign login session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=change-me-to-a-long-random-string

# Whisper model size: tiny | base | small | medium | large-v3
# Bigger = more accurate but slower and heavier on CPU/RAM.
ASR_MODEL=base

# Whisper engine: faster_whisper (lighter) | openai_whisper
ASR_ENGINE=faster_whisper

# transcribe = keep original language; translate = translate speech to English
WHISPER_TASK=transcribe

# Force a language (ISO code like "en", "si", "de"). Leave blank to auto-detect.
WHISPER_LANGUAGE=

# Host port for the web UI
PORT=8000
